# ==============================
# 通义千问 免费+低成本 官方配置
# 直接用你提供的阿里云 AK
# 模型：qwen3-turbo（免费额度最高，最便宜）
# ==============================
ALIBABA_CLOUD_ACCESS_KEY_ID=${{ secrets.AK_ID }}
ALIBABA_CLOUD_ACCESS_KEY_SECRET=${{ secrets.AK_SECRET }}
DASHSCOPE_MODEL=qwen3-turbo

# 邮箱配置（修改成读取 Secrets 的方式）
EMAIL_SENDER=${{ secrets.EMAIL_SENDER }}
EMAIL_PASSWORD=${{ secrets.EMAIL_PASSWORD }}
EMAIL_RECEIVER=${{ secrets.EMAIL_RECEIVER }}
EMAIL_SMTP_SERVER=smtp.qq.com
EMAIL_SMTP_PORT=465

# 股票数据接口
TUSHARE_TOKEN=120fe4accbf7f04075a33cbf35d69c2dd35c0c0f2697eb9f0aa67cad

# 关闭无用功能，避免报错
SEARCH_ENABLED=false
NEWS_ENABLED=false

